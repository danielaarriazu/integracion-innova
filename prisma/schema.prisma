// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            String        @id @default(uuid())
  nombre        String
  email         String        @unique
  password      String
  rol           Rol           @default(EMPRENDEDOR)
  estado        EstadoUsuario @default(ACTIVO)
  fechaRegistro DateTime      @default(now())
  ultimaSesion  DateTime?

  bot               ConfiguracionBot?
  historialSesiones HistorialSesion[]
  actividades       RegistroActividad[]
  Consulta          Consulta?           @relation(fields: [consultaId], references: [id])
  consultaId        String?
}

model HistorialSesion {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  fechaLogin  DateTime @default(now())
  //fechaFin    DateTime?
  dispositivo String?
  ip          String?
}

model ConfiguracionBot {
  id        String  @id @default(uuid())
  usuarioId String  @unique
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Estado y Datos del Negocio
  activo           Boolean @default(false)
  nombreNegocio    String?
  descripcionBreve String? @db.Text
  horarioAtencion  String?
  telefono         String?
  logoUrl          String?

  // Comportamiento del Bot
  mensajeBienvenida    String? @db.Text
  mensajeFueraHorario  String? @db.Text
  respuestaDerivacion  String? @db.Text
  derivacionAutomatica Boolean @default(false)
  slug                 String? @unique

  // historialSesiones
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  // Relaciones
  categoriasFAQ CategoriaFAQ[]
  faqs          Faq[]
  productos     Producto[]
  sesiones      SesionChat[]
  rubroId       String?
  rubro         Rubro?         @relation(fields: [rubroId], references: [id])
  Consulta      Consulta[]
}

model Rubro {
  id     String  @id @default(uuid())
  nombre String  @unique
  activo Boolean @default(true)

  bots ConfiguracionBot[]
}

model CategoriaFAQ {
  id     String           @id @default(uuid())
  botId  String
  bot    ConfiguracionBot @relation(fields: [botId], references: [id], onDelete: Cascade)
  nombre String

  faqs Faq[]

  fechaCreacion DateTime @default(now())
}

model Faq {
  id    String           @id @default(uuid())
  botId String
  bot   ConfiguracionBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  categoriaId String
  categoria   CategoriaFAQ @relation(fields: [categoriaId], references: [id], onDelete: Restrict)

  pregunta  String
  respuesta String  @db.Text
  activa    Boolean @default(true)
  //orden              Int?

  fechaCreacion     DateTime      @default(now())
  fechaModificacion DateTime      @updatedAt
  ConsultaFaq       ConsultaFaq[]
}

model Producto {
  id    String           @id @default(uuid())
  botId String
  bot   ConfiguracionBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  nombre      String
  descripcion String? @db.Text
  precio      Decimal @db.Decimal(10, 2)
  stock       Int     @default(0)
  urlImagen   String?
  activo      Boolean @default(true)

  fechaCreacion      DateTime           @default(now())
  fechaActualizacion DateTime           @updatedAt
  ConsultaProducto   ConsultaProducto[]
}

model SesionChat {
  id    String           @id @default(uuid())
  botId String
  bot   ConfiguracionBot @relation(fields: [botId], references: [id], onDelete: Cascade)

  numeroCliente String
  estado        EstadoChat @default(BOT_ACTIVO)

  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  // Se actualizó aquí también a botId y numeroCliente
  @@unique([botId, numeroCliente])
}

// Distintos roles que se maneja actualmente
enum Rol {
  ADMIN
  EMPRENDEDOR
}

// Estados para el emprendedor
enum EstadoUsuario {
  ACTIVO
  SUSPENDIDO
  ELIMINADO
}

// Estados para el control de la atención
enum EstadoChat {
  BOT_ACTIVO
  HUMANO_ATENDIENDO
}

enum EstadoConsulta {
  NUEVA
  EN_PROCESO
  RESUELTA
  CERRADA
}

enum CerradaPor {
  BOT
  ADMIN
  EMPRENDEDOR
  CLIENTE
}

model RegistroActividad {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  accion      String
  detalle     String   @db.Text
  ip          String?
  dispositivo String?
  fecha       DateTime @default(now())
}

model EventoTelemetry {
  id            String   @id @default(uuid())
  botId         String?
  sessionId     String
  tipoUsuario   String   @default("ANONIMO") // Posibles valores: ANONIMO, EMPRENDEDOR, CLIENTE
  usuarioId     String?
  ip            String   @default("desconocida")
  dispositivo   String   @default("desconocido")
  fechaServidor DateTime
  eventos       Json
  fechaCreacion DateTime @default(now())

  @@map("eventos_telemetry")
}

// 4. CONSULTA — núcleo del sistema, registra cada interacción
model Consulta {
  id                 String             @id @default(uuid())
  botId              String
  bot                ConfiguracionBot   @relation(fields: [botId], references: [id], onDelete: Cascade)
  sessionAnonimaId   String?
  clienteNombre      String?
  clienteTelefono    String?
  estado             EstadoConsulta     @default(NUEVA)
  derivada           Boolean            @default(false)
  cerradaPor         CerradaPor?
  tipoConsulta       String?
  prioridad          String?
  canal              String             @default("web")
  asunto             String?
  descripcion        String?            @db.Text
  derivadaA          String?
  fechaCreacion      DateTime           @default(now())
  fechaActualizacion DateTime           @updatedAt
  fechaCierre        DateTime?
  mensajes           Mensaje[]
  productos          ConsultaProducto[]
  Usuario            Usuario[]
  Lead               Lead?
  ConsultaFaq        ConsultaFaq[]

  @@index([botId, fechaActualizacion])
  @@index([sessionAnonimaId])
}

// rediseñar 6. MENSAJE — historial de mensajes dentro de cada consulta (autorreferencial)
model Mensaje {
  id                 String   @id @default(uuid())
  consultaId         String
  mensajePadreId     String?
  emisor             String
  contenido          String
  tipoMensaje        String?
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  leido              Boolean  @default(false)

  consulta     Consulta  @relation(fields: [consultaId], references: [id])
  mensajePadre Mensaje?  @relation("MensajeHilo", fields: [mensajePadreId], references: [id])
  respuestas   Mensaje[] @relation("MensajeHilo")
  adjuntos     Adjunto[]

  @@map("mensaje")
}

// 7. ADJUNTO — archivos adjuntos a mensajes  => se puede dejar para posible escalamiento. aunque
model Adjunto {
  id            String   @id @default(uuid())
  mensajeId     String
  url           String
  tipo          String?
  nombre        String?
  tamano        String?
  fechaCreacion DateTime @default(now())

  mensaje Mensaje @relation(fields: [mensajeId], references: [id])

  @@map("adjunto")
}

// 8. LEAD — datos de contacto capturados en la conversación (opcional por consulta) /// no va
model Lead {
  id                 String   @id @default(uuid())
  consultaId         String   @unique
  asignadoA          Int?
  nombre             String?
  email              String?
  telefono           String?
  empresa            String?
  motivoInteres      String?
  estado             String?
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt

  consulta Consulta @relation(fields: [consultaId], references: [id])

  @@map("lead")
}

// 10. CONSULTA_PRODUCTO — tabla intermedia Consulta ↔ Producto (N a N)
model ConsultaProducto {
  id         String @id @default(uuid())
  consultaId String

  productoId String
  cantidad   Int?
  detalle    String?

  consulta Consulta @relation(fields: [consultaId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id])

  @@map("consulta_producto")
}

// 13. CONSULTA_FAQ — tabla intermedia Consulta ↔ FAQ (N a N)
model ConsultaFaq {
  id            String   @id @default(uuid())
  consultaId    String
  faqId         String
  fechaConsulta DateTime @default(now())

  consulta Consulta @relation(fields: [consultaId], references: [id])
  faq      Faq      @relation(fields: [faqId], references: [id])

  @@map("consulta_faq")
}
