// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id           String            @id @default(uuid())
  nombre       String
  email        String            @unique
  password     String
  rol          Rol               @default(EMPRENDEDOR)
  estado       EstadoUsuario     @default(ACTIVO)
  fechaRegistro DateTime          @default(now())
  ultimaSesion DateTime?         
  bot          ConfiguracionBot? // Relación 1 a 1 con la configuración del bot
  historialSesiones HistorialSesion[] 
  actividades      RegistroActividad[]
}

model ConfiguracionBot {
  id               String   @id @default(uuid())
  usuario_id       String   @unique
  usuario          Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  activo           Boolean  @default(false)
  nombreNegocio    String?
  mensajeBienvenida String?  @db.Text
  tokenWhatsapp    String?
  fechaModificacion DateTime @updatedAt
}

model HistorialSesion {
  id           String   @id @default(uuid())
  usuario_id   String
  usuario      Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  fechaLogin   DateTime @default(now())
  dispositivo  String?
  ip           String?
}

enum Rol {
  ADMIN
  EMPRENDEDOR
}

enum EstadoUsuario {
  ACTIVO
  SUSPENDIDO
  ELIMINADO
}

model RegistroActividad {
  id          String   @id @default(uuid())
  usuario_id  String
  usuario     Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  accion      String   // Ej: "CAMBIO_PASSWORD", "EDICION_BOT", "LECTURA_REPORTE"
  detalle     String   @db.Text // Ej: "El usuario modificó el mensaje de bienvenida"
  ip          String?
  dispositivo String?
  fecha       DateTime @default(now())
}