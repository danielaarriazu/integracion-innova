PORT=3000

# Supabase PostgreSQL connection string
# En: Supabase > Project Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[TU-PASSWORD]@db.[TU-PROJECT-REF].supabase.co:5432/postgres

# JWT — clave secreta para firmar los tokens de autenticación
JWT_SECRET=cambia_esto_por_una_clave_secreta_segura
JWT_EXPIRES_IN=7d

# URL pública del servidor (solo en producción — Render la asigna automáticamente)
# En local NO hace falta — Swagger usa http://localhost:3000 por defecto
SERVER_URL=https://[nombre-de-tu-servicio].onrender.com
